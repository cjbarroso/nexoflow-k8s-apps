# Plaintext template for the Alertmanager -> incident-adapter bearer token.
# Mounted into the Alertmanager pod (extraSecretMounts: am-incident) and referenced
# via http_config.authorization.credentials_file in prometheus-values.yaml.
#
# Fill bearer-token with the SAME value you used for ALERTMANAGER_BEARER_TOKEN in
# the hermes2 adapter Secret, seal with kubeseal (namespace: observability), and
# commit ONLY the sealed output as alertmanager-incident-bearer-sealedsecret.yaml.
#
#   kubeseal --context nexoflow-cf --controller-name sealed-secrets-controller \
#     --controller-namespace kube-system --format yaml \
#     < /tmp/am-incident-bearer.yaml \
#     > src/observability/alertmanager-incident-bearer-sealedsecret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: alertmanager-incident-bearer
  namespace: observability
type: Opaque
stringData:
  bearer-token: "REPLACE_ME"
