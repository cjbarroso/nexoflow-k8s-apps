# Plaintaint template for the Alertmanager->Hermes adapter secret. Fill the real
# values, seal with kubeseal (see steps below), and commit ONLY the sealed output
# as alertmanager-incident-webhook-sealedsecret.yaml. Never commit this filled in.
#
# WEBHOOK_SECRET must match the incident-alerts route secret on the Hermes PVC
# (retrieve it from /opt/data/webhook_subscriptions.json on the IR pod).
# ALERTMANAGER_BEARER_TOKEN is the token you put in Alertmanager webhook_configs.
apiVersion: v1
kind: Secret
metadata:
  name: alertmanager-incident-webhook
  namespace: hermes2
type: Opaque
stringData:
  WEBHOOK_SECRET: "REPLACE_ME"
  ALERTMANAGER_BEARER_TOKEN: "REPLACE_ME"
